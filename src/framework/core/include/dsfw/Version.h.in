#pragma once

#define DSFW_VERSION_MAJOR @DSFW_VERSION_MAJOR@
#define DSFW_VERSION_MINOR @DSFW_VERSION_MINOR@
#define DSFW_VERSION_PATCH @DSFW_VERSION_PATCH@
#define DSFW_VERSION "@DSFW_VERSION@"

#define DSFW_MAKE_VERSION(major, minor, patch) (((major) << 16) | ((minor) << 8) | (patch))
#define DSFW_VERSION_NUMBER DSFW_MAKE_VERSION(DSFW_VERSION_MAJOR, DSFW_VERSION_MINOR, DSFW_VERSION_PATCH)
