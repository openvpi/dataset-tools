root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.bat]
end_of_line = crlf

[*.ps1]
end_of_line = crlf

[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[*.ts]
indent_size = 4

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2